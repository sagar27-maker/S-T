package demo;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import java.util.List;

public class ComboBox {

    public static void main(String[] args) {

        WebDriver driver = new ChromeDriver();

        try {
            driver.get("file:///C:/Users/DELL/Documents/combo1.html");
            driver.manage().window().maximize();

            List<WebElement> options =
                    driver.findElements(By.xpath("//select/option"));

            System.out.println("Number of options in combo box is: "
                    + options.size());

            for (WebElement option : options) {
                System.out.println(option.getText());
            }

            Thread.sleep(5000);   // Keeps the page open for 5 seconds

        } catch (InterruptedException e) {
            e.printStackTrace();
        } catch (Exception e) {
            e.printStackTrace();
        } finally {
            driver.quit();
        }
    }

<!DOCTYPE html>
<html>
<head>
<title> Combo Box Test </title>
</head>
<body>
<h2> Select your option: </h2>
<select id = MyDropdown">
<option value = "1"> option One </option>
<option value = "2"> option Two </option>
<option value = "3"> option Three </option>
</select>
</body>
</html>
}
